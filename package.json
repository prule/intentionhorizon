{
  "name": "intention-horizon",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Define intentions, tick them off, and watch your horizon.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright test; serenity-bdd run --destination target/site/serenity",
    "serenity-bdd:update": "serenity-bdd update"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@serenity-js/assertions": "^3.43.2",
    "@serenity-js/console-reporter": "^3.43.2",
    "@serenity-js/core": "^3.43.2",
    "@serenity-js/playwright": "^3.43.2",
    "@serenity-js/playwright-test": "^3.43.2",
    "@serenity-js/serenity-bdd": "^3.43.2",
    "@serenity-js/web": "^3.43.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-window": "^7.4.1"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
